{
  "name": "tap-to-track",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 0.0.0.0\" \"tsx watch server/index.ts\"",
    "build": "tsc -b && vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "test": "node node_modules/vitest/vitest.mjs run",
    "check": "tsc -b && eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/cookie": "latest",
    "@fastify/rate-limit": "latest",
    "@fastify/static": "latest",
    "@vite-pwa/assets-generator": "latest",
    "argon2": "latest",
    "better-sqlite3": "latest",
    "dexie": "latest",
    "fastify": "latest",
    "nanoid": "latest",
    "papaparse": "latest",
    "qrcode": "latest",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "ws": "latest",
    "xlsx": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "@types/papaparse": "latest",
    "@types/qrcode": "latest",
    "@types/react": "18.3.24",
    "@types/react-dom": "18.3.7",
    "@types/ws": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "prettier": "latest",
    "tailwindcss": "3.4.17",
    "tsx": "latest",
    "typescript": "6.0.3",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vite-plugin-pwa": "latest",
    "vitest": "latest"
  }
}
